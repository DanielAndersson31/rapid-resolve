# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./tickets.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname

# Ollama Configuration for Local LLM
OLLAMA_BASE_URL=http://localhost:11434
PRIVACY_SCREENING_MODEL=mixtral:7b
LLAMAINDEX_LLM_MODEL=mixtral:7b

# Whisper Configuration
WHISPER_MODEL_PATH=./models/
AUDIO_UPLOAD_PATH=./uploads/audio/
WHISPER_ENGLISH_MODEL=turbo
WHISPER_SWEDISH_MODEL=medium

# Application Configuration
MAX_AUDIO_SIZE_MB=25
MAX_AUDIO_DURATION_SECONDS=600
PRIVACY_CONFIDENCE_THRESHOLD=0.95
SUPPORTED_AUDIO_FORMATS=.mp3,.wav,.flac,.m4a

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_CORRELATION_ID=true

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LlamaIndex Configuration
LLAMAINDEX_DATA_PATH=./data/
LLAMAINDEX_VECTOR_STORE=simple
ENABLE_LLAMAINDEX_OBSERVABILITY=true

# Product Categories
SUPPORTED_CATEGORIES=laptops,phones,accessories
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,sv

# Development/Production Settings
ENVIRONMENT=development
DEBUG=true
RELOAD=true
HOST=0.0.0.0
PORT=8000

# External Service Configuration
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# File Storage
UPLOAD_DIR=./uploads/
TEMP_DIR=./temp/
LOG_DIR=./logs/

# Model Download Settings
AUTO_DOWNLOAD_MODELS=false
MODEL_CACHE_DIR=./models/cache/